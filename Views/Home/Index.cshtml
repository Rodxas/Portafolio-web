@model Domain.Entities.Persona

@{
    ViewData["Title"] = "Inicio";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-background"></div>
    <div class="container">
        <div class="row align-items-center min-vh-100">
            <div class="col-lg-6 hero-content">
                <span class="badge hero-badge mb-3">Disponible para trabajar</span>
                <h1 class="hero-title">
                    Hola, soy <span class="text-primary">@Model.Nombre</span>
                </h1>
                <p class="hero-subtitle">
                    Desarrollador Full Stack especializado en tecnologías <strong>.NET</strong> y <strong>JavaScript</strong>
                </p>
                <p class="hero-description">
                    Estudiante de ingeniería en sistemas en la Universidad Dominicana OyM. 
                    Capacitado para trabajar con clientes tanto en español como en inglés.
                </p>
                <div class="hero-cta">
                    <a href="#sobre-mi" class="btn btn-primary btn-lg me-3">
                        <i class="bi bi-arrow-down me-2"></i>Conóceme
                    </a>
                    <a href="https://drive.google.com/file/d/1tIMWTFkQEEsI2H27gZRrxW8AcekMafXs/view?usp=drive_link" target="_blank" class="btn btn-outline-primary btn-lg me-3">
                        <i class="bi bi-download me-2"></i>Descargar CV
                    </a>
                    <a href="#habilidades" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-code-slash me-2"></i>Mis Habilidades
                    </a>
                </div>
                <div class="hero-tech mt-4">
                    <span class="me-3">Tech stack:</span>
                    <i class="bi bi-filetype-cs tech-icon" title="C#"></i>
                    <i class="bi bi-filetype-js tech-icon" title="JavaScript"></i>
                    <i class="bi bi-filetype-html tech-icon" title="HTML"></i>
                    <i class="bi bi-filetype-css tech-icon" title="CSS"></i>
                    <i class="bi bi-database tech-icon" title="MySQL"></i>
                </div>
            </div>
            <div class="col-lg-6 text-center hero-image-container">
                <div class="image-wrapper">
                    <img id="foto" 
                         src="~/imagenes/CV foto Rodney_Polanco.jpg" 
                         alt="Foto de Rodney Polanco" 
                         class="img-fluid profile-image"
                         loading="lazy" />
                    <div class="image-decoration"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="scroll-indicator">
        <a href="#sobre-mi">
            <i class="bi bi-chevron-down"></i>
        </a>
    </div>
</section>

<!-- Sobre Mí Section -->
<section id="sobre-mi" class="section-about">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="section-header text-center mb-5">
                    <span class="section-tag">Sobre Mí</span>
                    <h2 class="section-title">Conoce más sobre mí</h2>
                </div>
                <div class="about-card">
                    <div class="row">
                        <div class="col-lg-4 text-center mb-4 mb-lg-0">
                            <img src="~/imagenes/CV foto Rodney_Polanco.jpg" 
                                 alt="Rodney Polanco" 
                                 class="about-image img-fluid"
                                 loading="lazy" />
                        </div>
                        <div class="col-lg-8">
                            <h3 class="mb-3">Desarrollador Full Stack en formación</h3>
                            <p class="mb-3">
                                Soy un profesional de <strong>@Model.Edad años</strong> apasionado por la tecnología y el desarrollo de software. 
                                Me especializo en crear soluciones robustas tanto en el backend como en el frontend.
                            </p>
                            <p class="mb-4">
                                Mi formación incluye conocimientos en <strong>Ofimática, Redes, cableado estructurado, 
                                Windows Server 2025, Cámaras CCTV e IPTV</strong>. En el ámbito del desarrollo, trabajo con 
                                <strong>C#, ASP.NET Core, MySQL, Entity Framework</strong> y estoy en constante aprendizaje de 
                                <strong>JavaScript, HTML y CSS</strong>.
                            </p>
                            <div class="about-features">
                                <div class="feature-item">
                                    <i class="bi bi-translate"></i>
                                    <span>Bilingüe (Español/Inglés)</span>
                                </div>
                                <div class="feature-item">
                                    <i class="bi bi-lightbulb"></i>
                                    <span>Enfoque en soluciones</span>
                                </div>
                                <div class="feature-item">
                                    <i class="bi bi-book"></i>
                                    <span>Aprendizaje continuo</span>
                                </div>
                                <div class="feature-item">
                                    <i class="bi bi-people"></i>
                                    <span>Trabajo en equipo</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Habilidades Section -->
<section id="habilidades" class="section-skills">
    <div class="container">
        <div class="section-header text-center mb-5">
            <span class="section-tag">Habilidades</span>
            <h2 class="section-title">Mis conocimientos técnicos</h2>
            <p class="section-subtitle">Tecnologías y herramientas con las que trabajo</p>
        </div>
        
        <div class="row g-4 justify-content-center">
            <!-- Backend Card -->
            <div class="col-md-6 col-lg-5">
                <div class="skill-card">
                    <div class="skill-icon">
                        <i class="bi bi-server"></i>
                    </div>
                    <h3 class="skill-title">Back-end</h3>
                    <p class="skill-description">
                        Desarrollo de APIs REST, lógica de negocio y gestión de bases de datos.
                    </p>
                    <div class="skill-tech">
                        <span class="tech-badge">ASP.NET Core</span>
                        <span class="tech-badge">C#</span>
                        <span class="tech-badge">MySQL</span>
                        <span class="tech-badge">Entity Framework</span>
                    </div>
                    <ul class="skill-list">
                        <li><i class="bi bi-check-circle-fill"></i> APIs REST</li>
                        <li><i class="bi bi-check-circle-fill"></i> Patrones de diseño (Singleton, Adapter, Factory)</li>
                        <li><i class="bi bi-check-circle-fill"></i> Arquitectura N-Layer</li>
                        <li><i class="bi bi-check-circle-fill"></i> Principios SOLID</li>
                        <li><i class="bi bi-check-circle-fill"></i> Postman</li>
                    </ul>
                </div>
            </div>

            <!-- Frontend Card -->
            <div class="col-md-6 col-lg-5">
                <div class="skill-card">
                    <div class="skill-icon">
                        <i class="bi bi-layout-text-window-reverse"></i>
                    </div>
                    <h3 class="skill-title">Front-end</h3>
                    <p class="skill-description">
                        Creación de interfaces de usuario responsivas y dinámicas.
                    </p>
                    <div class="skill-tech">
                        <span class="tech-badge">Angular</span>
                        <span class="tech-badge">TypeScript</span>
                        <span class="tech-badge">Blazor</span>
                        <span class="tech-badge">JavaScript</span>
                        <span class="tech-badge">HTML5</span>
                        <span class="tech-badge">CSS3</span>
                        <span class="tech-badge">Bootstrap</span>
                    </div>
                    <ul class="skill-list">
                        <li><i class="bi bi-check-circle-fill"></i> Angular 21 (Signals, Standalone Components)</li>
                        <li><i class="bi bi-check-circle-fill"></i> TypeScript</li>
                        <li><i class="bi bi-check-circle-fill"></i> Angular Material</li>
                        <li><i class="bi bi-check-circle-fill"></i> JSON / HttpClient</li>
                        <li><i class="bi bi-check-circle-fill"></i> Diseño responsivo</li>
                        <li><i class="bi bi-check-circle-fill"></i> UI/UX básico</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Additional Skills -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="additional-skills">
                    <h4 class="text-center mb-4"><i class="bi bi-tools me-2"></i>Conocimientos Adicionales</h4>
                    <div class="row g-3">
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="additional-skill-item">
                                <i class="bi bi-diagram-3"></i>
                                <span>Redes</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="additional-skill-item">
                                <i class="bi bi-hdd"></i>
                                <span>Windows Server</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="additional-skill-item">
                                <i class="bi bi-camera-video"></i>
                                <span>CCTV</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="additional-skill-item">
                                <i class="bi bi-wifi"></i>
                                <span>IPTV</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="additional-skill-item">
                                <i class="bi bi-ethernet"></i>
                                <span>Cableado</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="additional-skill-item">
                                <i class="bi bi-file-earmark-word"></i>
                                <span>Ofimática</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

